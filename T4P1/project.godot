; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RV T4P1 - Realidad Mixta"
config/description="Proyecto de RA/RM con Godot 4.6 y Meta Quest"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

XRToolsUserSettings="*uid://n1gm6kyfauju"
XRToolsRumbleManager="*uid://c732tsjkx860k"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[editor_plugins]

enabled=PackedStringArray("res://addons/godot-xr-tools/plugin.cfg")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
viewport/transparent_background=true

[xr]

openxr/enabled=true
openxr/environment_blend_mode=2
openxr/startup_alert=false
shaders/enabled=true
openxr/action_map="res://openxr_action_map.tres"
openxr/extensions/meta/passthrough=true
openxr/extensions/meta/render_model=true
